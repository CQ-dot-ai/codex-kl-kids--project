.page {
  min-height: 100vh;
  padding: 20rpx 24rpx 56rpx;
  background: #f7f3ea;
}

.hero {
  padding: 40rpx 32rpx;
  border: 1rpx solid #eadfce;
  border-radius: 24rpx;
  color: #3a2d24;
  background: linear-gradient(135deg, #fff7e8 0%, #f9dfbd 58%, #e8f2e8 100%);
  box-shadow: 0 18rpx 44rpx rgba(88, 60, 35, 0.08);
}

.eyebrow {
  color: #b45d3f;
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  text-transform: uppercase;
}

.title {
  margin-top: 14rpx;
  font-size: 58rpx;
  font-weight: 900;
  line-height: 1.05;
}

.intro {
  margin-top: 18rpx;
  color: #725f51;
  font-size: 28rpx;
  line-height: 1.65;
}

.pick {
  margin-top: 28rpx;
  padding: 24rpx;
  border: 1rpx solid #e4d4be;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.72);
}

.pick-label,
.pick-note {
  color: #7a6b5e;
  font-size: 24rpx;
}

.pick-name {
  margin: 8rpx 0;
  font-size: 34rpx;
  font-weight: 850;
}

.hero-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 24rpx;
}

.share-btn,
.map-primary {
  height: 76rpx;
  margin: 0;
  border-radius: 12rpx;
  color: #ffffff;
  background: #246b54;
  font-size: 28rpx;
  font-weight: 800;
}

.map-primary {
  color: #246b54;
  background: #ffffff;
  border: 1rpx solid #cdded4;
}

.filters {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 20rpx;
}

.filter-item {
  display: flex;
  min-height: 94rpx;
  padding: 16rpx 18rpx;
  border: 1rpx solid #d9dfd8;
  border-radius: 18rpx;
  background: #ffffff;
  flex-direction: column;
  justify-content: center;
}

.filter-item text:first-child {
  color: #66736e;
  font-size: 22rpx;
}

.filter-item text:last-child {
  margin-top: 6rpx;
  color: #17201d;
  font-size: 28rpx;
  font-weight: 760;
}

.stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin-top: 20rpx;
}

.stats view {
  display: flex;
  min-height: 112rpx;
  border: 1rpx solid #d9dfd8;
  border-radius: 18rpx;
  background: #ffffff;
  align-items: center;
  flex-direction: column;
  justify-content: center;
}

.stats text:first-child {
  color: #246b54;
  font-size: 36rpx;
  font-weight: 900;
}

.stats text:last-child {
  margin-top: 4rpx;
  color: #66736e;
  font-size: 20rpx;
}

.section-head {
  display: flex;
  margin-top: 34rpx;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  color: #17201d;
  font-size: 34rpx;
  font-weight: 880;
}

.section-meta {
  margin-top: 6rpx;
  color: #66736e;
  font-size: 24rpx;
}

.plain-btn {
  width: auto;
  min-width: 112rpx;
  height: 62rpx;
  margin: 0;
  padding: 0 22rpx;
  border: 1rpx solid #d9dfd8;
  border-radius: 12rpx;
  color: #246b54;
  background: #ffffff;
  font-size: 26rpx;
  font-weight: 760;
}

.reminder-card {
  display: flex;
  gap: 18rpx;
  margin-top: 20rpx;
  padding: 24rpx;
  border: 1rpx solid #eadfce;
  border-radius: 20rpx;
  background: #fffaf0;
  align-items: center;
  justify-content: space-between;
}

.reminder-title {
  color: #3a2d24;
  font-size: 30rpx;
  font-weight: 860;
}

.reminder-text {
  margin-top: 8rpx;
  color: #725f51;
  font-size: 25rpx;
  line-height: 1.45;
}

.reminder-hint {
  margin-top: 6rpx;
  color: #9b7a5d;
  font-size: 22rpx;
  line-height: 1.45;
}

.reminder-btn {
  width: 132rpx;
  height: 66rpx;
  margin: 0;
  border-radius: 999rpx;
  color: #ffffff;
  background: #d96b5f;
  font-size: 26rpx;
  font-weight: 820;
  flex-shrink: 0;
}

.place-card,
.event-card,
.empty {
  margin-top: 18rpx;
  padding: 24rpx;
  border: 1rpx solid #d9dfd8;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 36rpx rgba(33, 49, 42, 0.06);
}

.card-top {
  display: flex;
  gap: 16rpx;
  justify-content: space-between;
}

.area {
  color: #246b54;
  font-size: 22rpx;
  font-weight: 800;
}

.place-name {
  margin-top: 8rpx;
  color: #17201d;
  font-size: 34rpx;
  font-weight: 850;
  line-height: 1.24;
}

.ease {
  display: flex;
  width: 88rpx;
  height: 88rpx;
  border-radius: 14rpx;
  color: #246b54;
  background: #e4f0ea;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 28rpx;
  font-weight: 900;
}

.summary {
  margin-top: 18rpx;
  color: #66736e;
  font-size: 28rpx;
  line-height: 1.62;
}

.metrics {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 18rpx;
}

.metrics view {
  display: flex;
  min-height: 92rpx;
  padding: 10rpx;
  border-radius: 12rpx;
  background: #f7faf7;
  flex-direction: column;
  justify-content: center;
}

.metrics text:first-child {
  color: #66736e;
  font-size: 20rpx;
}

.metrics text:last-child {
  margin-top: 6rpx;
  color: #17201d;
  font-size: 25rpx;
  font-weight: 800;
}

.decision {
  display: grid;
  gap: 12rpx;
  margin-top: 18rpx;
  color: #66736e;
  font-size: 27rpx;
  line-height: 1.55;
}

.decision text {
  margin-right: 12rpx;
  color: #17201d;
  font-weight: 820;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.tags text,
.event-status {
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  color: #246b54;
  background: #eef5f1;
  font-size: 22rpx;
  font-weight: 760;
}

.map-actions {
  display: grid;
  grid-template-columns: 1.2fr 1fr 1fr;
  gap: 10rpx;
  margin-top: 18rpx;
}

.solid-map,
.copy-btn,
.source-btn {
  height: 66rpx;
  margin: 0;
  border: 1rpx solid #d9dfd8;
  border-radius: 12rpx;
  color: #315d8c;
  background: #ffffff;
  font-size: 25rpx;
  font-weight: 760;
}

.solid-map {
  color: #ffffff;
  background: #246b54;
  border-color: #246b54;
}

.source-btn {
  margin-top: 14rpx;
  color: #66736e;
}

.event-head {
  align-items: flex-start;
}

.event-card {
  border-left: 8rpx solid #d96b5f;
}

.event-status {
  display: inline-flex;
  align-self: flex-start;
}

.event-title {
  margin-top: 14rpx;
  color: #17201d;
  font-size: 30rpx;
  font-weight: 840;
  line-height: 1.35;
}

.event-line,
.event-note {
  margin-top: 10rpx;
  color: #66736e;
  font-size: 26rpx;
  line-height: 1.5;
}

.empty {
  color: #66736e;
  font-size: 28rpx;
}
